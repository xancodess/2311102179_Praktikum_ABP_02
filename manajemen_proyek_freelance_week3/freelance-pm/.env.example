# ============================================================
# Freelance Video PM — Environment Variables
# ============================================================
# Salin file ini menjadi .env dan isi dengan credential Anda
# cp .env.example .env

# ── Google OAuth2 ──────────────────────────────────────────
# Dapatkan dari: https://console.cloud.google.com/
# 1. Buat project baru
# 2. Enable "Google Calendar API"
# 3. Buat OAuth2 Client ID (Web Application)
# 4. Tambahkan redirect URI: http://localhost:3000/auth/google/callback

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ── Session ────────────────────────────────────────────────
SESSION_SECRET=ganti-dengan-string-rahasia-acak-anda

# ── Server ─────────────────────────────────────────────────
PORT=3000
